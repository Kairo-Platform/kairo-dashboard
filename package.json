{
  "name": "kairo-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:admin": "turbo dev --filter=@kairo/admin-dashboard",
    "dev:enterprise": "turbo dev --filter=@kairo/enterprise-dashboard",
    "build": "turbo build",
    "build:admin": "turbo build --filter=@kairo/admin-dashboard",
    "build:enterprise": "turbo build --filter=@kairo/enterprise-dashboard",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.9"
}
